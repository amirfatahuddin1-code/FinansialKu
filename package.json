{
  "name": "karsafin",
  "version": "1.0.0",
  "main": "packages/mobile/index.js",
  "private": true,
  "description": "Karsafin - Atur Keuangan, Wujudkan Mimpi (Monorepo)",
  "workspaces": [
    "packages/shared",
    "packages/web",
    "packages/mobile"
  ],
  "scripts": {
    "postinstall": "npm run shared:build",
    "shared:build": "npm run build --workspace=packages/shared",
    "web:dev": "npm run dev --workspace=packages/web",
    "web:build": "npm run build --workspace=packages/web",
    "mobile:start": "npm run start --workspace=packages/mobile",
    "mobile:android": "npm run android --workspace=packages/mobile",
    "android": "cd packages/mobile && npx expo run:android",
    "ios": "cd packages/mobile && npx expo run:ios"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@radix-ui/react-slot": "^1.2.4"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.8",
    "color": "^5.0.3",
    "dexie": "^4.0.1",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.0",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "next-pwa": "^5.6.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-purchases": "^10.1.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  }
}
